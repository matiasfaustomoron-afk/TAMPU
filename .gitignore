# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
credentials.json
*.bak
*.old

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Supabase migration bundle (derived artifact for manual SQL Editor paste)
supabase/migrations-bundle.sql
supabase/copy-bundle.ps1

# vercel / netlify deploy outputs
.vercel
.netlify

# typescript
*.tsbuildinfo
next-env.d.ts

# capacitor / iOS native build (generated via npm run cap:add:ios)
/ios/App/Pods/
/ios/App/App.xcworkspace/xcuserdata/
/ios/App/App.xcodeproj/xcuserdata/
/ios/App/build/
/ios/DerivedData/
DerivedData/
*.xcuserstate

# capacitor cache
.capacitor/

# playwright artifacts
/test-results/
/playwright-report/
/playwright/.cache/
